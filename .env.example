# Copier ce fichier en .env et remplir les valeurs
# Le fichier .env ne doit jamais être commité

PORT=8080
DEBUG=true

# Base de données MySQL
# En docker-compose : DB_HOST=db  (nom du service)
DB_HOST=localhost
DB_PORT=3306
DB_USER=alterconso
DB_PASSWORD=changeme
DB_NAME=alterconso

# JWT — générer avec : openssl rand -hex 32
JWT_SECRET=changeme_generate_a_strong_random_secret

# Clé applicative (utilisée pour le hash MD5 des mots de passe Haxe)
# Doit être identique à la valeur 'key' de l'ancien config.xml
APP_KEY=changeme

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=changeme
DEFAULT_EMAIL=noreply@alterconso.fr

# Domaine public
HOST=localhost
