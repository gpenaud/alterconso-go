# Alterconso — fichier de configuration
# Copier en config.yaml et adapter les valeurs.
# Les secrets (mots de passe, clés) peuvent aussi être passés
# via variables d'environnement (priorité sur ce fichier).

# Serveur
port: "8080"
debug: false

# Base de données MySQL
db_host: localhost
db_port: "3306"
db_user: alterconso
db_password: ""        # ou env DB_PASSWORD
db_name: alterconso

# Authentification
jwt_secret: ""         # ou env JWT_SECRET — générer : openssl rand -hex 32
jwt_expiry_hours: 168  # 7 jours

# Clé applicative (hash MD5 mots de passe legacy)
key: ""                # ou env APP_KEY

# Domaine public (utilisé dans les liens des emails)
host: alterconso.leportail.org

# Superadmin global (créé/maintenu au démarrage si email renseigné).
# Compte avec tous les droits sur tous les groupes : peut créer et gérer
# n'importe quel groupe. Voit toujours la page de choix de groupe au login.
superadmin:
  email: ""              # ex: admin@alterconso.fr (vide = désactivé)
  password: ""           # ou env SUPERADMIN_PASSWORD
  first_name: Super
  last_name: Admin

# Email — SMTP Brevo
smtp_host: smtp-relay.brevo.com
smtp_port: "587"
smtp_user: ""          # ou env SMTP_USER (adresse email Brevo)
smtp_password: ""      # ou env SMTP_PASSWORD (clé API Brevo)
default_email: noreply@alterconso.fr

# Catégories de destinataires de la page /messages.
# Format de pattern : "<op> N commande[s] sur Tm"
#   op : <, <=, >, >=, =
#   N  : nombre de commandes (distributions distinctes)
#   T  : nombre de mois sur lequel on regarde en arrière
# Les catégories sont mutuellement exclusives : un user appartient à la
# première catégorie qui matche dans l'ordre du fichier (du plus engagé au
# moins engagé).
messages:
  recipient_categories:
    - name: "Membres réguliers"
      pattern: ">= 3 commandes sur 3m"
    - name: "Membres occasionnels"
      pattern: ">= 1 commande sur 6m"
    - name: "Membres inactifs"
      pattern: "< 1 commande sur 6m"

# Notifications
notifications:
  # Catégorie (parmi messages.recipient_categories) dont les membres reçoivent
  # les notifications d'ouverture/fermeture des commandes.
  # Sémantique : pure correspondance par pattern, sans exclusivité mutuelle.
  # Obligatoire — boot fatal si vide ou nom inconnu.
  recipient_category: "Membres réguliers"
